# MACI Elyria Seam Pilot Environment

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080

PUBLIC_SAFE_MODE=true
POLICY_VERSION=ELYRIA_MACI_PUBLIC_SEAM_POLICY_V0_2

# Boundary engine mode:
# public-safe = use committed public-safe fallback adapter
# private     = load external private module; do not commit private logic
ELYRIA_BOUNDARY_ENGINE=public-safe

# Example only. Do not commit actual private engine code.
# ELYRIA_PRIVATE_BOUNDARY_MODULE=elyria_private.engine:evaluate_boundary

# Production deployments require separate written commercial scope.
COMMERCIAL_USE_ALLOWED=false
