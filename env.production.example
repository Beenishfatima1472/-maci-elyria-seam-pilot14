# Elyria / MACI Production Runtime Candidate Environment
# Public-safe template only. Do not commit real secrets.

APP_ENV=production

ELYRIA_REQUIRE_AUTH=true
ELYRIA_REQUIRE_TENANT=true
ELYRIA_AUDIT_ENABLED=true

# API key format:
# key_id:secret-with-at-least-32-characters:role1,role2:tenant-id
ELYRIA_API_KEYS=admin:replace-with-production-secret-at-least-32-chars:admin:tenant-a

ELYRIA_RECEIPT_SIGNING_KEY=replace-with-production-signing-key-at-least-32-chars
ELYRIA_RECEIPT_KEY_ID=production-key-id

ELYRIA_BOUNDARY_ENGINE=private
ELYRIA_PRIVATE_BOUNDARY_MODULE=elyria_private.engine:evaluate_boundary

ELYRIA_AUDIT_STORE_PATH=runtime/audit/audit-log.jsonl
ELYRIA_RECEIPT_STORE_PATH=runtime/receipts
